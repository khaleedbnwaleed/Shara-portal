# Git LFS - track common image formats under public/asset and asset folders
public/asset/** filter=lfs diff=lfs merge=lfs -text
public/image/** filter=lfs diff=lfs merge=lfs -text
asset/** filter=lfs diff=lfs merge=lfs -text

# Fallback by extension (covers any other locations)
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text
*.avif filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
